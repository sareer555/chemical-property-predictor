# =============================================================================
# Chemical Property Prediction - Environment Configuration
# =============================================================================

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# Streamlit Dashboard
STREAMLIT_PORT=8501
STREAMLIT_THEME=dark

# Data Collection
PUBCHEM_BATCH_SIZE=100
PUBCHEM_MAX_RETRIES=3
PUBCHEM_RATE_LIMIT=5

# Model Paths
MODEL_DIR=models/saved
CHECKPOINT_DIR=models/checkpoints

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# Feature Engineering
MORGAN_RADIUS=2
MORGAN_NBITS=2048

# Cross-Validation
CV_FOLDS=5
RANDOM_STATE=42

# Training
N_ESTIMATORS=100
MAX_DEPTH=10
LEARNING_RATE=0.1
